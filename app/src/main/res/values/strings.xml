    <string name="main_credits_title">Thanks to open source projects</string>
    <string name="main_credits_body">This app builds on open‑source software. Thank you to the authors and contributors of:\n\n• yt‑dlp — https://github.com/yt-dlp/yt-dlp\n• FFmpeg — https://ffmpeg.org\n• youtubedl‑android — https://github.com/yausername/youtubedl-android (maintained packages used by this app)\n• NanoHTTPD — https://github.com/NanoHttpd/nanohttpd\n• Android Jetpack (AndroidX), Material Components\n• Media3 (ExoPlayer) — https://developer.android.com/jetpack/androidx/releases/media3\n• Google Cast SDK for Android\n• Coil — https://github.com/coil-kt/coil\n• Kotlin — https://kotlinlang.org\n\n… and all other libraries bundled with the app.</string>

