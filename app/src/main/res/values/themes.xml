<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.DLPulse.Steam" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/steam_brass</item>
        <item name="colorPrimaryDark">@color/steam_bg</item>
        <item name="colorAccent">@color/steam_copper</item>
        <item name="android:colorBackground">@color/steam_bg</item>
        <item name="android:windowBackground">@color/steam_bg</item>
        <item name="android:textColorPrimary">@color/steam_parchment</item>
        <item name="android:textColorSecondary">@color/steam_parchment_dim</item>
        <item name="actionBarStyle">@style/Widget.DLPulse.ActionBar</item>
        <item name="android:statusBarColor">@color/steam_bg</item>
        <item name="android:navigationBarColor">@color/steam_bg</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
    </style>

    <style name="Widget.DLPulse.ActionBar" parent="Widget.AppCompat.Light.ActionBar.Solid">
        <item name="background">@color/steam_bg_panel</item>
        <item name="titleTextStyle">@style/TextAppearance.DLPulse.Title</item>
    </style>

    <style name="TextAppearance.DLPulse.Title" parent="TextAppearance.AppCompat.Widget.ActionBar.Title">
        <item name="android:textColor">@color/steam_brass</item>
        <item name="android:fontFamily">serif</item>
    </style>

    <style name="Theme.DLPulse.NoActionBar" parent="Theme.DLPulse.Steam">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.DLPulse.Player" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:colorBackground">@android:color/black</item>
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">@android:color/black</item>
        <item name="android:navigationBarColor">@android:color/black</item>
    </style>

    <style name="Widget.DLPulse.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:minHeight">@dimen/btn_min_height</item>
        <item name="android:textSize">@dimen/btn_text_size</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingLeft">20dp</item>
        <item name="android:paddingRight">20dp</item>
        <item name="backgroundTint">@null</item>
        <item name="android:background">@drawable/btn_primary_steampunk</item>
        <item name="android:textColor">#1A1208</item>
    </style>
</resources>
